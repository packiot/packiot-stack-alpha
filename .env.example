# Copy to .env.local and fill in the values.
# These vars supplement the hard-coded infra values in compose.integration.yml.
# Connection strings (DB host/port, PubSub emulator, Hasura URL) are already
# set by the compose file — only secrets and service identifiers go here.

# ─── Edge Node-RED ────────────────────────────────────────────────────────────
NODE_RED_CREDENTIAL_SECRET=changeme-min-32-chars-long-secret-edge
# SparkPlug topic this edge instance publishes to (must match packml_register)
ID_PUBSUB_NODE=machine-01-node-id
ID_ENTERPRISE=1
# API key for edge-api calls (must match the api_key in the enterprises table)
API_KEY=dev-api-key

# ─── OEECloud Node-RED ────────────────────────────────────────────────────────
# Reuses NODE_RED_CREDENTIAL_SECRET and ID_ENTERPRISE from above if identical,
# or override with a second value if you run both on different secrets.
# NODE_RED_CREDENTIAL_SECRET_OEECLOUD=changeme-min-32-chars-long-secret-oee

# Alerting (optional in dev — leave as-is to silence alert sends)
ALERT_EMAIL_TO=dev@example.com
ALERT_EMAIL_FROM=support@packiot.com
SENDGRID_API_KEY=SG.dev-placeholder-not-used-locally
PING_API_URL=http://edge-api:8080/devices/ping

# ─── Edge API (NestJS) ────────────────────────────────────────────────────────
# DB credentials are hard-coded in compose.integration.yml (postgres/packiot).
# Add any edge-api specific secrets here if needed in the future.
# LOG_LEVEL=info
