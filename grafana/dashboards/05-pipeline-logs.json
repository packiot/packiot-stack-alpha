          "type": "loki",
          "uid": "packiot-loki"
        },
        "query": {
          "type": "labelValues",
          "label": "service"
        },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "current": {}
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "current": {
          "value": ""
        },
        "query": ""
      }
    ]
  },
