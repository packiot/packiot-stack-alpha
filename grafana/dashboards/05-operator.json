{
  "uid": "packiot-operator",
  "title": "Operator Activity",
  "description": "Per-user operator insights: logins, PO actions, downtime justification rate, and event throughput",
  "tags": [
    "packiot",
    "operator",
    "oee",
    "users"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "time": {
    "from": "now-8h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "enterprise",
        "label": "Enterprise",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "packiot-postgres"
        },
        "query": "SELECT nm_enterprise FROM enterprises WHERE active = true ORDER BY nm_enterprise",
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "user",
        "label": "User",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "packiot-postgres"
        },
        "query": "SELECT DISTINCT nm_user FROM user_logs ORDER BY nm_user",
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": "All"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Users (last 8h)",
      "description": "Distinct users who performed at least one action",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT COUNT(DISTINCT nm_user) as value FROM user_logs WHERE ts_log >= $__timeFrom() AND ts_log <= $__timeTo()",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "PO Actions",
      "description": "Start / change / stop PO operations (30800-30899 parameter range)",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT COUNT(*) as value FROM user_logs WHERE ts_log >= $__timeFrom() AND ts_log <= $__timeTo() AND category IN ('order-started','order-stopped') AND ('${enterprise:csv}' = '.*' OR id_enterprise IN (SELECT id_enterprise FROM enterprises WHERE nm_enterprise = ANY(string_to_array('${enterprise:csv}', ','))))",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Events Justified",
      "description": "Downtime events that operators categorised in the selected window",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "orange",
                "value": 50
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT COUNT(*) as value FROM user_logs WHERE ts_log >= $__timeFrom() AND ts_log <= $__timeTo() AND category IN ('event-justified','event-edited') AND ('${enterprise:csv}' = '.*' OR id_enterprise IN (SELECT id_enterprise FROM enterprises WHERE nm_enterprise = ANY(string_to_array('${enterprise:csv}', ','))))",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Manual Events Added",
      "description": "Manual downtime events inserted via the operator UI",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT COUNT(*) as value FROM user_logs WHERE ts_log >= $__timeFrom() AND ts_log <= $__timeTo() AND category = 'manual-event-created' AND ('${enterprise:csv}' = '.*' OR id_enterprise IN (SELECT id_enterprise FROM enterprises WHERE nm_enterprise = ANY(string_to_array('${enterprise:csv}', ','))))",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Justification Rate",
      "description": "% of closed downtime events that have been categorised by an operator",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT ROUND(100.0 * COUNT(*) FILTER (WHERE cd_category IS NOT NULL AND cd_category <> '') / NULLIF(COUNT(*), 0), 1) AS value FROM equipment_events WHERE ts_end >= $__timeFrom() AND ts_end <= $__timeTo()",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Pending Events Right Now",
      "description": "Open equipment events with no ts_end — awaiting justification",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT COUNT(*) as value FROM equipment_events WHERE ts_end IS NULL",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Operator Actions Over Time",
      "description": "Stacked: PO starts, event justifications, manual events — shows when the floor is active",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "lineWidth": 0,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT $__timeGroup(ts_log,'$__interval',0) AS time, COUNT(*) AS \"PO Actions\" FROM user_logs WHERE ts_log BETWEEN $__timeFrom() AND $__timeTo() AND category IN ('order-started','order-stopped') GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT $__timeGroup(ts_log,'$__interval',0) AS time, COUNT(*) AS \"Justifications\" FROM user_logs WHERE ts_log BETWEEN $__timeFrom() AND $__timeTo() AND category IN ('event-justified','event-edited') GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT $__timeGroup(ts_log,'$__interval',0) AS time, COUNT(*) AS \"Manual Events\" FROM user_logs WHERE ts_log BETWEEN $__timeFrom() AND $__timeTo() AND category = 'manual-event-created' GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Actions per User",
      "description": "Total operator actions broken down by username — shows who is most active",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 12
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "values": true,
          "calcs": ["lastNotNull"],
          "limit": 20
        },
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT nm_user, COUNT(*) AS actions FROM user_logs WHERE ts_log BETWEEN $__timeFrom() AND $__timeTo() AND ('${user:csv}' = 'All' OR nm_user = ANY(string_to_array('${user:csv}', ','))) AND ('${enterprise:csv}' = '.*' OR id_enterprise IN (SELECT id_enterprise FROM enterprises WHERE nm_enterprise = ANY(string_to_array('${enterprise:csv}', ',')))) GROUP BY nm_user ORDER BY actions DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "piechart",
      "title": "Action Type Distribution",
      "description": "Breakdown of operator action categories over the selected window",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 12
      },
      "options": {
        "pieType": "donut",
        "displayLabels": ["name", "percent"],
        "legend": {
          "displayMode": "list",
          "placement": "right"
        },
        "tooltip": {
          "mode": "single"
        },
        "reduceOptions": {
          "values": true,
          "calcs": ["lastNotNull"],
          "limit": 20
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT COALESCE(category, 'unknown') AS action, COUNT(*) AS count FROM user_logs WHERE ts_log BETWEEN $__timeFrom() AND $__timeTo() AND ('${user:csv}' = 'All' OR nm_user = ANY(string_to_array('${user:csv}', ','))) AND ('${enterprise:csv}' = '.*' OR id_enterprise IN (SELECT id_enterprise FROM enterprises WHERE nm_enterprise = ANY(string_to_array('${enterprise:csv}', ',')))) GROUP BY 1 ORDER BY count DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "Downtime Backlog — Longest Pending Events",
      "description": "Events open with no justification, ordered by how long they have been open. Highlights gaps in operator responsiveness.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 12
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Open (min)",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Open (min)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "m"
              },
              {
                "id": "custom.width",
                "value": 90
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 15
                    },
                    {
                      "color": "red",
                      "value": 60
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT e.id_equipment, pr.packml_topic AS topic, ROUND(EXTRACT(EPOCH FROM (now() - e.ts_event)) / 60.0) AS \"Open (min)\", e.ts_event FROM equipment_events e LEFT JOIN packml_register pr ON pr.id_equipment = e.id_equipment WHERE e.ts_end IS NULL ORDER BY \"Open (min)\" DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Downtime Events — Pending vs Justified per Hour",
      "description": "Tracks how quickly operators close the justification backlog. A rising 'pending' line means the floor is falling behind.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Pending"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Justified"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT $__timeGroup(ts_event,'1h',0) AS time, COUNT(*) AS \"Pending\" FROM equipment_events WHERE ts_event BETWEEN $__timeFrom() AND $__timeTo() AND ts_end IS NULL GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT $__timeGroup(ts_end,'1h',0) AS time, COUNT(*) AS \"Justified\" FROM equipment_events WHERE ts_end BETWEEN $__timeFrom() AND $__timeTo() AND cd_category IS NOT NULL GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "B"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Production Orders Started / Stopped per Hour",
      "description": "When operators kick off or close POs — correlate with shift schedules to spot idle periods.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Started"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Finished"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT $__timeGroup(ts_start,'1h',0) AS time, COUNT(*) AS \"Started\" FROM production_orders WHERE ts_start BETWEEN $__timeFrom() AND $__timeTo() AND status >= 2 GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT $__timeGroup(ts_end,'1h',0) AS time, COUNT(*) AS \"Finished\" FROM production_orders WHERE ts_end BETWEEN $__timeFrom() AND $__timeTo() AND status = 3 GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "B"
        }
      ]
    },
    {
      "id": 13,
      "type": "table",
      "title": "Per-User Action Log",
      "description": "Full audit trail of operator actions. Use the User filter above to scope to a single operator.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "options": {
        "sortBy": [
          {
            "displayName": "When",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "When"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsLocal"
              },
              {
                "id": "custom.width",
                "value": 160
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "category"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "subcategory"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 120
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "packiot-postgres"
          },
          "rawSql": "SELECT ts_log AS \"When\", nm_user AS \"User\", category, COALESCE(payload->>'descCategory', '') AS \"Category\", COALESCE(payload->>'cdSubcategory', '') AS \"Subcategory\", COALESCE(payload->>'descSubcategory', payload->>'txtDowntimeNotes', '') AS \"Detail\", id_equipment AS \"Equipment\" FROM user_logs WHERE ts_log BETWEEN $__timeFrom() AND $__timeTo() AND ('${user:csv}' = 'All' OR nm_user = ANY(string_to_array('${user:csv}', ','))) AND ('${enterprise:csv}' = '.*' OR id_enterprise IN (SELECT id_enterprise FROM enterprises WHERE nm_enterprise = ANY(string_to_array('${enterprise:csv}', ',')))) ORDER BY ts_log DESC LIMIT 500",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "type": "logs",
      "title": "Operator Service Logs",
      "description": "Live container logs from the operator service (React Vite dev server)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 38
      },
      "options": {
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "packiot-loki"
          },
          "expr": "{service=\"operator\"}",
          "refId": "A"
        }
      ]
    }
  ]
}