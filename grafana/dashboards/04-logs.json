{
  "uid": "packiot-logs",
  "title": "Stack Logs",
  "description": "Live log streams from all Packiot services via Loki + Promtail",
  "tags": ["packiot", "logs", "observability"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "packiot-loki" },
        "query": {
          "label": "service",
          "refId": "LokiVariableQueryEditor-VariableQuery",
          "stream": "",
          "type": "labelValues"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "query": "",
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Log Volume (selected range)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "packiot-loki" },
        "expr": "sum(count_over_time({service=~\"$service\"} [$__interval]))",
        "legendFormat": "log lines",
        "refId": "A"
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Count",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 10 }
          ]}
        }
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "packiot-loki" },
        "expr": "sum(count_over_time({service=~\"$service\"} |~ \"(?i)(error|exception|failed|critical)\" [$__interval]))",
        "legendFormat": "errors",
        "refId": "A"
      }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Log Volume Over Time by Service",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 4 },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 0, "stacking": { "mode": "normal", "group": "A" } }
        }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "packiot-loki" },
          "expr": "sum by (service) (count_over_time({service=~\"$service\"} [$__interval]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "postgres",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 11 },
      "options": {
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "packiot-loki" },
        "expr": "{service=\"postgres\"} |~ \"$search\"",
        "refId": "A"
      }]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "edge-api",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 11 },
      "options": {
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "packiot-loki" },
        "expr": "{service=\"edge-api\"} |~ \"$search\"",
        "refId": "A"
      }]
    },
    {
      "id": 6,
      "type": "logs",
      "title": "edge-nodered",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 21 },
      "options": {
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "packiot-loki" },
        "expr": "{service=\"edge-nodered\"} |~ \"$search\"",
        "refId": "A"
      }]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "oeecloud",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 21 },
      "options": {
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "packiot-loki" },
        "expr": "{service=\"oeecloud\"} |~ \"$search\"",
        "refId": "A"
      }]
    },
    {
      "id": 9,
      "type": "logs",
      "title": "operator",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 31 },
      "options": {
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "packiot-loki" },
        "expr": "{service=\"operator\"} |~ \"$search\"",
        "refId": "A"
      }]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "All Services — Errors & Warnings",
      "description": "Filtered to error/warn/exception lines across the whole stack",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 41 },
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      },
      "targets": [{
        "datasource": { "type": "loki", "uid": "packiot-loki" },
        "expr": "{service=~\"$service\"} |~ \"(?i)(error|warn|exception|failed|critical)\" |~ \"$search\"",
        "legendFormat": "{{service}}",
        "refId": "A"
      }]
    }
  ]
}
